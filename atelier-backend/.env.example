# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── JWT (generate with: openssl rand -hex 32) ───────────────────────────────
JWT_ACCESS_SECRET=change_me_32_random_hex_chars
JWT_REFRESH_SECRET=change_me_32_random_hex_chars_2

# ── Cookie ──────────────────────────────────────────────────────────────────
COOKIE_SECRET=change_me_random_string

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=/var/lib/atelier/atelier.db

# ── Initial admin (only used on first startup) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=StrongPassword123!

# ── Bank transfer details ────────────────────────────────────────────────────
BANK_IBAN=DE00 0000 0000 0000 0000 00
BANK_BIC=XXXXXXXX
BANK_HOLDER=Atelier GmbH
BANK_NAME=Musterbank

# ── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your_smtp_password
MANUFACTURER_EMAIL=orders@your-domain.com

# ── Python ML Environment ──────────────────────────────────────────────────
# Path to Python binary with ML dependencies (numpy, scipy, opencv, sklearn).
# Leave empty to auto-detect: checks atelier-ml/.venv → ~/ml-venv → system python3.
# On PEP 668 systems (Ubuntu 24.04+), a venv is REQUIRED — system pip install
# will fail with "externally-managed-environment".
# PYTHON_PATH=/home/nrply/ml-venv/bin/python3

# ── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://raza.work
# Frontend origin for CORS + cookie settings
FRONTEND_URL=https://raza.work
# NOTE: VITE_API_URL belongs in atelier-app/.env.production, NOT here.
# The backend .env has no effect on Vite build-time variables.
